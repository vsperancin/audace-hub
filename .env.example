# =============================================================================
# Audace Hub — Variáveis de ambiente (template)
# =============================================================================
# Copie este arquivo para `.env.local` (desenvolvimento) ou configure as
# variáveis diretamente no Coolify (produção). NUNCA commite `.env.local`.
# =============================================================================

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
# URL pública do app — usada em callbacks OAuth, redirects e emails.
# - Dev:    http://localhost:3000
# - Prod:   https://app.audacehub.com.br
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Supabase (Auth + Database + RLS)
# -----------------------------------------------------------------------------
# URL do projeto Supabase (auto-hospedado no Coolify ou cloud).
# Encontre em: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://supabase.example.com"

# Chave ANON (pública) — usada pelo browser/RSC para queries com RLS.
# Pode ser exposta no client, desde que RLS esteja ativo nas tabelas.
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."

# Chave SERVICE_ROLE (SECRETA) — bypassa RLS, usada APENAS em server-side
# para operações administrativas (ex: inserir tokens OAuth criptografados).
# NUNCA exponha no client. NUNCA commite.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# -----------------------------------------------------------------------------
# Mercado Livre OAuth
# -----------------------------------------------------------------------------
# App ID (chamado também de client_id). Obtenha em:
#   https://developers.mercadolivre.com.br/devcenter/apps
# Após criar a aplicação, anote o "Client ID".
ML_APP_ID="1234567890123456"

# Secret do app (NUNCA exponha). Obtenha no mesmo painel do App ID.
ML_CLIENT_SECRET="ABC123def456..."

# URL de redirect OAuth — DEVE estar cadastrada EXATAMENTE assim no painel
# do seu app ML. Default: ${NEXT_PUBLIC_APP_URL}/api/oauth/ml/callback
ML_REDIRECT_URI="http://localhost:3000/api/oauth/ml/callback"

# -----------------------------------------------------------------------------
# Criptografia de tokens (AES-256-GCM)
# -----------------------------------------------------------------------------
# Chave de 32 bytes (256 bits) em base64.
# Gere uma nova com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY="

# -----------------------------------------------------------------------------
# Redis (cache + filas BullMQ) — opcional, usado em features futuras
# -----------------------------------------------------------------------------
# Em dev: localhost. Em prod: serviço Redis no Coolify ou Upstash.
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# Observabilidade (opcional)
# -----------------------------------------------------------------------------
# Sentry DSN para tracking de erros server-side e client-side.
NEXT_PUBLIC_SENTRY_DSN=""

# Ambiente — 'development' | 'staging' | 'production'
NODE_ENV="development"

# -----------------------------------------------------------------------------
# Mercado Livre client (opcional — defaults funcionam sem setar)
# -----------------------------------------------------------------------------
# Timeout por request (ms). Default: 30000
ML_TIMEOUT_MS="30000"

# Tentativas em retry exponencial. Default: 3
ML_MAX_RETRIES="3"

# Backoff base (ms). Default: 500
ML_BASE_BACKOFF_MS="500"

# Backoff máximo (ms). Default: 30000
ML_MAX_BACKOFF_MS="30000"

# Refresh token N ms antes de expirar. Default: 300000 (5 min)
ML_REFRESH_LEAD_MS="300000"

# Rate limiter — capacidade do bucket. Default: 10
ML_RATE_LIMIT_CAPACITY="10"

# Rate limiter — refill por segundo. Default: 10
ML_RATE_LIMIT_REFILL_PER_SECOND="10"

# Rate limiter — timeout de aquisição (ms). Default: 60000
ML_RATE_LIMIT_ACQUIRE_TIMEOUT_MS="60000"